{
  "manifest_version": 3,
  "name": "NQ-Assistant",
  "version": "2.3.0",
  "description": "多平台 AI 回复提取、编辑、模板导出 Word",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "NQ-Assistant - 打开侧边面板"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://kimi.moonshot.cn/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ],
      "css": ["lib/floatpanel.css"],
      "js": [
        "lib/docx.bundle.js",
        "lib/latex2omml.js",
        "lib/marked.min.js",
        "lib/highlight.min.js",
        "lib/turndown.min.js",
        "lib/md2docx.js",
        "lib/katex.min.js",
        "lib/markdown-it.min.js",
        "lib/html2pdf.bundle.min.js",
        "lib/floatpanel.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://kimi.moonshot.cn/*",
    "https://www.doubao.com/*",
    "https://doubao.com/*"
  ],
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/katex.min.css", "icons/icon48.png"],
      "matches": [
        "https://chat.deepseek.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://kimi.moonshot.cn/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ]
    }
  ]
}
